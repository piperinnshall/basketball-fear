Bound: {
  .x: X; .y: Y; .width: Width; .height: Height;
  .inBounds(x: X, y: Y): Bool ->
    x.get >= (this.x.get) 
    && { x.get <= (this.x.get + (this.width.get)) } 
    && { y.get >= (this.y.get) }
    && { y.get <= (this.y.get + (this.height.get)) };
  }

MenuBounds: { #(width: Width, height: Height): Bound -> Block#
  .let w = { (width.get * 2).div 5 } .let h = { height.get.div 5 }
  .return {{ 
    .x -> X#((width.get - w).div 2); .y -> Y#((height.get - h).div 2); 
    .width -> Width#w; .height -> Height#h;
    }}}

SquareBounds: { #(x: Nat, y: Nat, width: Width, height: Height): Bound -> Block#
  .let w = { (width.get).div 10 } .let h = { width.get.div 12 }
  .return {{
    .x -> X#x; .y -> Y#y;
    .width -> Width#w; .height -> Height#h;
    }}}

PlayerBounds: { #(x: Nat, y: Nat, width: Width, height: Height): Bound -> Block#
  .let size = { (width.get).div 12 }
  .return {{ 
    .x -> X#x; .y -> Y#y;
    .width -> Width#size; .height -> Height#size;
    }}}

BallBounds: { #(x: Nat, y: Nat, width: Width, height: Height): BallBound -> Block#
  .let size = { (width.get).div 16 }
  .return {{
    .x -> X#x; .y -> Y#y;
    .width -> Width#size; .height -> Height#size;
    .screenWidth -> width;
    .screenHeight -> height;
    }}}

BallBound: Bound {
    .screenWidth: Width;
    .screenHeight: Height;
    .overlapsRect(bx: Num, by: Num, bounds: Bound): Bool -> Block#
      .let[imm Num] px          = { bounds.x.get.num }
      .let[imm Num] py          = { bounds.y.get.num }
      .let[imm Num] boundW      = { bounds.width.get.num }
      .let[imm Num] boundH      = { bounds.height.get.num }
      .let[imm Num] ballW       = { this.width.get.num }
      .let[imm Num] ballH       = { this.height.get.num }
      .let[imm Num] ballRight   = { bx + ballW }
      .let[imm Num] ballBottom  = { by + ballH }
      .let[imm Num] boundRight  = { px + boundW }
      .let[imm Num] boundBottom  = { py + boundH }
      .return {
        ballRight > px
        && { bx < boundRight }
        && { ballBottom > py }
        && { by < boundBottom }
        };
    .bounceOffPlayer(bx: Num, player: read Player): Num -> Block#
      .let playerBounds           = { PlayerBounds#(player.x, player.y, this.screenWidth, this.screenHeight) }
      .let[imm Num] px            = { playerBounds.x.get.num }
      .let[imm Num] playerW       = { playerBounds.width.get.num }
      .let[imm Num] playerCenter  = { px + (playerW / (2.num)) }
      .let[imm Num] ballCenter    = { bx + (this.width.get.num / (2.num)) }
      .return {
        (ballCenter - playerCenter) / (playerW / (2.num)) * (8.num)
        }}
